{
  "manifest_version": 3,
  "name": "Discord Camera Unmirror",
  "description": "Toggle the horizontal flip on your camera feed in Discord video calls",
  "version": "1.1.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Discord Camera Unmirror",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*",
        "https://canary.discord.com/*",
        "https://ptb.discord.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
